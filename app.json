{
  "expo": {
    "name": "Mi Rutina",
    "slug": "mi-rutina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mirутина.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B0B"
      },
      "package": "com.mirutina.app"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "mirutina"
  }
}
